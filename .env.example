# Base URL of the VTD FastAPI backend.
# Used for REST (/alerts) and to derive the WebSocket URL (/ws).
VITE_API_URL=http://localhost:8000

# Base URL of the camera device's live MJPEG video stream (served by the pipeline,
# default port 8090). The Live Cameras screen embeds <STREAM_URL>/stream.
# For a remote camera, point this at the device, e.g. http://192.168.1.50:8090
VITE_STREAM_URL=http://localhost:8090
